    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorjs.io": "^0.6.1",
    "comlink": "^4.4.2",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.575.0",
    "mediabunny": "^1.36.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hotkeys-hook": "^5.2.4",
