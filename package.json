    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.app.json",
    "test": "vitest",
    "test:vrt": "vitest --project vrt"
  },
  "dependencies": {
