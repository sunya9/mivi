{
  "name": "midi-visualizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsgo -b && vite build",
    "generate-pwa-assets": "pwa-assets-generator",
