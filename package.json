    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.58.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^3.8.5",
